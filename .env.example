# repowise Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# LLM Provider API Keys (set at least one)
# ---------------------------------------------------------------------------

# Anthropic (recommended for best results)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama — no API key needed, but set base URL if non-default
# OLLAMA_BASE_URL=http://localhost:11434

# LiteLLM proxy (for Together AI, Replicate, Groq, etc.)
# LITELLM_API_KEY=your_litellm_key_here
# LITELLM_BASE_URL=http://localhost:4000

# OpenAI-Compatible LLM Provider (local/self-hosted)
# For Ollama, LM Studio, vLLM, Azure OpenAI, etc.
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPATIBLE_API_KEY=your_key_here  # Optional (leave blank for Ollama)

# ---------------------------------------------------------------------------
# Embedder Configuration
# ---------------------------------------------------------------------------

# OpenAI Embedder (default: text-embedding-3-small)
# OPENAI_API_KEY=your_openai_key_here  # Uses OPENAI_API_KEY above

# OpenAI-Compatible Embedder (RAG/Vector Search)
# Uses same OPENAI_COMPATIBLE_BASE_URL and OPENAI_COMPATIBLE_API_KEY as above
# Embedding model name is specified via CLI and saved to <config-dir>/config.yaml:
#   repowise init --embedder openai_compatible --embedder-model nomic-embed-text-v2-moe:latest
#   repowise reindex --embedder openai_compatible --embedder-model all-minilm-l6-v2

# Gemini Embedder
# GEMINI_API_KEY=your_gemini_key_here

# OpenRouter Embedder
# OPENROUTER_API_KEY=your_openrouter_key_here

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite (default, no setup required)
DATABASE_URL=sqlite+aiosqlite:///./repowise.db

# PostgreSQL (optional, for production deployments)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/repowise

# ---------------------------------------------------------------------------
# Storage Paths
# ---------------------------------------------------------------------------

# LanceDB vector store path (used when DATABASE_URL is SQLite)
# When DATABASE_URL is PostgreSQL, pgvector is used instead — no separate path needed
LANCEDB_PATH=./data/lancedb

# Dependency graph storage path
GRAPH_PATH=./data/graphs

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Optional API key to protect repowise API endpoints
# Leave empty for fully open access (suitable for local use)
REPOWISE_API_KEY=

# Server bind address and port
REPOWISE_HOST=0.0.0.0
REPOWISE_PORT=7337

# MCP server port (SSE transport)
REPOWISE_MCP_PORT=7338

# ---------------------------------------------------------------------------
# Generation Defaults
# ---------------------------------------------------------------------------

# Default provider: anthropic | openai | ollama | litellm | openai_compatible
REPOWISE_DEFAULT_PROVIDER=anthropic

# Default model (depends on provider)
REPOWISE_DEFAULT_MODEL=claude-sonnet-4-6

# Default embedder: gemini | openai | openai_compatible | openrouter
# If not set, repowise auto-detects from available API keys/base URLs
# REPOWISE_DEFAULT_EMBEDDER=openai_compatible

# Max concurrent LLM calls during generation
REPOWISE_MAX_CONCURRENT=5

# Reasoning mode for supported docs-generation providers: auto | off | minimal
# auto = provider default; off = disable Qwen3/OpenRouter effort reasoning when supported;
# minimal = request the lowest supported OpenAI/OpenRouter reasoning effort.
# Unsupported explicit modes fail before an API call.
REPOWISE_REASONING=auto

# Max pages to regenerate per maintenance run
REPOWISE_CASCADE_BUDGET=30

# ---------------------------------------------------------------------------
# Development
# ---------------------------------------------------------------------------

# Set to "true" to enable debug logging
REPOWISE_DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
REPOWISE_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Example: Local Ollama Setup (Chat + Embedding with Centralized Config)
# ---------------------------------------------------------------------------
# Uncomment and modify these lines for local Ollama with centralized config:
#
# REPOWISE_CONFIG_DIR=C:\tools\repowise
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
# # No API key needed for local Ollama
#
# Then run (once):
#   repowise init \
#     --provider openai_compatible --model qwen2.5-coder:3b \
#     --embedder openai_compatible --embedder-model nomic-embed-text-v2-moe:latest
#
# This saves to C:\tools\repowise\config.yaml:
#   provider: openai_compatible
#   model: qwen2.5-coder:3b
#   embedder: openai_compatible
#   embedder_model: nomic-embed-text-v2-moe:latest
#
# Subsequent runs use the saved config automatically:
#   repowise serve
#   repowise reindex
#   repowise update

# ---------------------------------------------------------------------------
# Example: Microsoft Foundry Setup (Chat + Embedding with API Key)
# ---------------------------------------------------------------------------
# Uncomment and modify these lines for Microsoft Foundry with API key auth:
#
# REPOWISE_CONFIG_DIR=C:\tools\repowise
# OPENAI_COMPATIBLE_BASE_URL=https://YOUR-RESOURCE-NAME.openai.azure.com/openai/v1
# OPENAI_COMPATIBLE_API_KEY=your-foundry-api-key-here
#
# Then run (once):
#   repowise init \
#     --provider openai_compatible --model gpt-4o-mini \
#     --embedder openai_compatible --embedder-model text-embedding-3-small
#
# This saves to C:\tools\repowise\config.yaml:
#   provider: openai_compatible
#   model: gpt-4o-mini
#   embedder: openai_compatible
#   embedder_model: text-embedding-3-small
#
# Subsequent runs use the saved config automatically:
#   repowise serve
#   repowise reindex
#   repowise update
#
# Find your resource name and API key in:
#   - Azure Portal → Your Resource → Keys and Endpoint
#   - Microsoft Foundry portal (ai.azure.com)

